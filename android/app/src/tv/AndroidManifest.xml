<?xml version="1.0" encoding="utf-8"?>
<!--
  TV flavor manifest overlay.
  Merged on top of main/AndroidManifest.xml by the build system.
  Adds: LEANBACK_LAUNCHER, android:banner, sensorLandscape orientation.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- TV has no touchscreen — mark it optional so the launcher includes us -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback" android:required="true" />

    <application
        android:banner="@drawable/tv_banner"
        tools:replace="android:banner">

        <activity
            android:name=".MainActivity"
            android:screenOrientation="sensorLandscape"
            tools:replace="android:screenOrientation">

            <!-- TV home screen entry point (replaces LAUNCHER for the TV flavor) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>
